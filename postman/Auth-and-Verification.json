{
  "info": {
    "name": "Auth & User Management – Table Booking",
    "description": "Auth (register/signin/me) and admin user management endpoints. Set `baseUrl` (e.g. http://localhost:5001/api/v1) and `bearerToken` (Firebase ID token from client after login).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5001/api/v1" },
    { "key": "bearerToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (public)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"{{firebaseIdToken}}\",\n  \"displayName\": \"John Doe\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "POST /auth/register — Public registration. Use Firebase ID token from createUserWithEmailAndPassword."
          }
        },
        {
          "name": "Signin (public)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"{{firebaseIdToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signin",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "signin"]
            },
            "description": "POST /auth/signin — Sign in using Firebase ID token. Returns profile (role, isEmailVerified, etc.)."
          }
        },
        {
          "name": "Get current user (me)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            },
            "description": "GET /auth/me — Returns the authenticated user profile (id, uid, email, role, isEmailVerified, isEligibleForCoupons)."
          }
        }
      ]
    },
    {
      "name": "User Management (Admin)",
      "item": [
        {
          "name": "List users (GET with query)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/usermanagement/users?page=1&limit=20&role=user&status=active&isEmailVerified=true",
              "host": ["{{baseUrl}}"],
              "path": ["usermanagement", "users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "role", "value": "user" },
                { "key": "status", "value": "active" },
                { "key": "isEmailVerified", "value": "true" }
              ]
            },
            "description": "GET /usermanagement/users — Paginated list of users with optional filters. Requires admin role."
          }
        },
        {
          "name": "List users (POST with body filters)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"page\": 1,\n  \"limit\": 25,\n  \"role\": [\"user\", \"staff\", \"admin\"],\n  \"status\": [\"active\", \"inactive\"],\n  \"isEmailVerified\": \"true\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/usermanagement/users/list",
              "host": ["{{baseUrl}}"],
              "path": ["usermanagement", "users", "list"]
            },
            "description": "POST /usermanagement/users/list — List users with filters in request body. Requires admin role."
          }
        },
        {
          "name": "Add user (admin creates Firebase-linked user)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"{{newUserFirebaseIdToken}}\",\n  \"username\": \"New Staff User\",\n  \"mobile\": \"9876543210\",\n  \"role\": \"staff\",\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/usermanagement/users",
              "host": ["{{baseUrl}}"],
              "path": ["usermanagement", "users"]
            },
            "description": "POST /usermanagement/users — Admin adds a user by sending Firebase idToken plus profile fields. Backend upserts MongoDB user."
          }
        },
        {
          "name": "Update user (username / role / status)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"Updated User Name\",\n  \"role\": \"admin\",\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/usermanagement/users/:id",
              "host": ["{{baseUrl}}"],
              "path": ["usermanagement", "users", ":id"]
            },
            "description": "PATCH /usermanagement/users/:id — Update displayName, role and/or status. Replace :id with user _id."
          }
        },
        {
          "name": "Set user status (soft delete / reactivate)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{bearerToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"inactive\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/usermanagement/users/:id/status",
              "host": ["{{baseUrl}}"],
              "path": ["usermanagement", "users", ":id", "status"]
            },
            "description": "PATCH /usermanagement/users/:id/status — Set user status to active or inactive (soft delete)."
          }
        }
      ]
    }
  ]
}
