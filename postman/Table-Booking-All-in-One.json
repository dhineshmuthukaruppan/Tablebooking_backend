                  { "key": "Content-Type", "value": "application/json", "type": "text" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"page\": 1,\n  \"limit\": 25,\n  \"status\": [\"pending\", \"confirmed\", \"completed\"],\n  \"bookingDateStart\": \"2026-03-01\",\n  \"bookingDateEnd\": \"2026-03-31\",\n  \"feedback\": \"required\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/admin/bookings/list",
                  "host": ["{{baseUrl}}"],
                  "path": ["admin", "bookings", "list"]
                }
              }
