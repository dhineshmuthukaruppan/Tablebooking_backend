                  "raw": "{\n  \"status\": \"completed\",\n  \"billing\": {\n    \"actualAmount\": 2000,\n    \"discountAmount\": 100,\n    \"finalAmount\": 1900,\n    \"customDiscount\": false\n  },\n  \"payment\": {\n    \"status\": \"paid\",\n    \"method\": \"cash\"\n  },\n  \"feedbackRequired\": true\n}"
