{
  "info": {
    "name": "Admin – Table Booking",
    "description": "Admin-facing APIs for Table Booking Backend. Set `baseUrl` (e.g. http://localhost:5001/api/v1) and `bearerToken` (Firebase ID token from client after login).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5001/api/v1" },
    { "key": "bearerToken", "value": "" }
  ],
  "item": [
    {
      "name": "Admin",
      "item": [
        {
          "name": "Bookings",
          "item": [
            {
              "name": "List bookings (admin/staff, paginated + filters)",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{bearerToken}}",
                    "type": "text"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json",
                    "type": "text"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"page\": 1,\n  \"limit\": 25,\n  \"status\": [\"pending\", \"confirmed\", \"completed\"],\n  \"bookingDateStart\": \"2025-03-01\",\n  \"bookingDateEnd\": \"2025-03-31\",\n  \"name\": \"john\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"9876\",\n  \"guestCount\": 4,\n  \"section\": [\"Indoor\", \"Rooftop\"],\n  \"feedback\": \"required\"\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/admin/bookings/list",
                  "host": ["{{baseUrl}}"],
                  "path": ["admin", "bookings", "list"]
                },
                "description": "POST /admin/bookings/list — Admin/staff list bookings with server-side pagination and filters."
              }
            },
            {
              "name": "Update booking (status / billing / payment / feedbackRequired)",
              "request": {
                "method": "PATCH",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{bearerToken}}",
                    "type": "text"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json",
                    "type": "text"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"status\": \"completed\",\n  \"billing\": {\n    \"actualAmount\": 2000,\n    \"discountAmount\": 200,\n    \"finalAmount\": 1800\n  },\n  \"payment\": {\n    \"status\": \"paid\",\n    \"method\": \"cash\",\n    \"stripePaymentIntentId\": null,\n    \"paidAt\": \"2025-03-12T19:45:00.000Z\"\n  },\n  \"feedbackRequired\": true\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/admin/bookings/:id",
                  "host": ["{{baseUrl}}"],
                  "path": ["admin", "bookings", ":id"]
                },
                "description": "PATCH /admin/bookings/:id — Update booking status, billing, payment and/or feedbackRequired. Replace :id with booking _id."
              }
            },
            {
              "name": "Walk-in booking payment (admin/staff)",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{bearerToken}}",
                    "type": "text"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json",
                    "type": "text"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"customerName\": \"Walk-in Customer\",\n  \"customerPhone\": \"9876543210\",\n  \"guestCount\": 2,\n  \"sectionName\": \"Indoor\",\n  \"bookingDate\": \"2025-03-12\",\n  \"billing\": {\n    \"actualAmount\": 1500,\n    \"discountAmount\": 0,\n    \"finalAmount\": 1500\n  },\n  \"payment\": {\n    \"status\": \"paid\",\n    \"method\": \"cash\"\n  }\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/admin/bookings/walk-in",
                  "host": ["{{baseUrl}}"],
                  "path": ["admin", "bookings", "walk-in"]
                },
                "description": "POST /admin/bookings/walk-in — Create/update a booking with walk-in payment details."
              }
            }
          ]
        },
